## template, rename to .env and fill

# Secret key, generate with:
# python -c 'import random; print "".join([random.choice("abcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*(-_=+)") for i in range(50)])'
# generate your key
#DJANGO_SECRET_KEY=

# ALLOWED_HOSTS - IP oddelene carkou bez mezery
# Include your domain(s), e.g. tournament.example.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,tournament.example.com

# DJANGO DEBUG
DJANGO_DEBUG=False

# DJANGO PORT
DJANGO_PORT=8844

# Public domain pointing to this server (A/AAAA DNS record required)
CADDY_DOMAIN=tournament.example.com

# Email used for Let's Encrypt registration and expiry notices
CADDY_EMAIL=admin@example.com
